theme = Catppuccin Frappe

macos-icon-frame = chrome
macos-titlebar-proxy-icon = visible
macos-titlebar-style = tabs

font-family = Inconsolata Nerd Font
font-size = 22
font-thicken = true
font-thicken-strength = 96

adjust-cell-width = -1
adjust-cell-height = 2

adjust-cursor-thickness = 3

window-inherit-working-directory = true
window-padding-balance = true

background-opacity = 1
background-blur = true


unfocused-split-fill = #1e1e2e
split-divider-color = #33aadd

shell-integration-features = no-cursor
cursor-style = block
cursor-style-blink = true

keybind = cmd+a>v=new_split:right
keybind = cmd+a>b=new_split:down

keybind = cmd+a>k=goto_split:top
keybind = cmd+a>l=goto_split:right
keybind = cmd+a>j=goto_split:bottom
keybind = cmd+a>h=goto_split:left
keybind = cmd+a>x=close_surface

keybind = cmd+shift+k=resize_split:up,10
keybind = cmd+shift+j=resize_split:down,10
keybind = cmd+shift+h=resize_split:left,10
keybind = cmd+shift+l=resize_split:right,10

keybind = global:cmd+ctrl+opt+shift+l=toggle_quick_terminal

